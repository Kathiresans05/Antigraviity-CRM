{
  "name": "crm-app",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run comm-server\" \"wait-on http://localhost:3000/login && node launcher.js\"",
    "dev:live": "cross-env CRM_LIVE_MODE=true node launcher.js",
    "build": "next build",
    "build:desktop": "npm run build && electron-builder",
    "start": "node server.js",
    "electron": "node launcher.js",
    "electron:live": "cross-env CRM_LIVE_MODE=true node launcher.js",
    "comm-server": "tsx backend/communication-server.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^3.0.0",
    "active-win": "^9.0.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "moment": "^2.30.1",
    "mongoose": "^9.2.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "screenshot-desktop": "^1.15.3",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/simple-peer": "^9.11.9",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.antigraviity.crm",
    "productName": "Antigraviity CRM",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "public/logo_highres.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "overrides": {
    "tar": "^6.2.1"
  }
}

